# Trading Tracker Configuration
# Copy this file to .env and customize values

# === Environment ===
PROJECT_ENV=development
DEBUG=False

# === Database ===
DATABASE_URL=sqlite:///./trading_tracker.db

# === Security ===
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# === Exchange Rates API ===
# Using European Central Bank (free, no API key required)
USE_EXCHANGE_RATE_API=True

# Optional: For Open Exchange Rates (if you want to use it instead of ECB)
# OPENEXCHANGERATES_API_KEY=your_api_key_here

# Optional: For Alpha Vantage API
# ALPHAVANTAGE_API_KEY=your_api_key_here

# Exchange Rate Cache TTL (Time To Live) in seconds
# Default: 3600 (1 hour)
EXCHANGE_RATE_CACHE_TTL=3600

# === File Upload ===
MAX_UPLOAD_SIZE_MB=10
UPLOAD_FOLDER=uploads/

# === Logging ===
LOG_LEVEL=INFO
LOG_FILE=trading_tracker.log

# === CORS ===
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8000
